{
    "Author": "T.J. Lauerman aka ThatSportsGamer",
    "CodePath": "plugin.js",
    "Description": "Shows live MLB scores on your Stream Deck. Each button tracks one team — see the current score, inning, and game status at a glance.",
    "Name": "Live MLB Scores",
    "Icon": "imgs/plugin-icon",
    "Version": "1.0.1",
    "SDKVersion": 2,
    "Software": {
        "MinimumVersion": "6.0"
    },
    "OS": [
        { "Platform": "mac", "MinimumVersion": "10.15" },
        { "Platform": "windows", "MinimumVersion": "10" }
    ],
    "Nodejs": {
        "Version": "20",
        "Debug": "enabled"
    },
    "Actions": [
        {
            "Name": "Live MLB Scores",
            "UUID": "com.tj.livemlbscores.score",
            "Icon": "imgs/action-icon",
            "Tooltip": "Shows live score for your chosen MLB team. Updates every 30 seconds.",
            "PropertyInspectorPath": "property-inspector.html",
            "States": [
                {
                    "Image": "imgs/action-icon",
                    "Title": ""
                }
            ],
            "SupportedInMultiActions": false
        }
    ]
}
